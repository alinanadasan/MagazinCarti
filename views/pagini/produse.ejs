<!DOCTYPE html>
<html lang="ro">
<head>
    <title>Produse BookNest</title>
    <meta name="description" content="Catalogul de cărți BookNest cu filtre după nume, descriere, autor, preț, format, limbă, teme și noutăți.">
    <meta name="keywords" content="BookNest, produse, cărți, catalog, filtre, librărie online">

    <%- include("../fragmente/head") %>
</head>
<body>
    <%- include("../fragmente/header") %>

    <main class="pagina-produse">
        <section class="zona">
            <h2>Catalog de cărți</h2>

            <% if (locals.categorieSelectata && categorieSelectata !== "toate") { %>
                <p>
                    Sunt afișate cărțile din categoria:
                    <strong><%= etichetaCategorie(categorieSelectata) %></strong>.
                </p>
            <% } else { %>
                <p>
                    Sunt afișate toate cărțile disponibile în catalogul BookNest.
                </p>
            <% } %>
        </section>

        <% 
            let preturi = produse.map(function(carte){
                return Number(carte.pret);
            });

            let pretMin = preturi.length ? Math.floor(Math.min(...preturi)) : 0;
            let pretMax = preturi.length ? Math.ceil(Math.max(...preturi)) : 100;

            let autori = [...new Set(produse.map(function(carte){
                return carte.autor;
            }).filter(Boolean))].sort();

            let formate = [...new Set(produse.map(function(carte){
                return carte.format;
            }).filter(Boolean))].sort();

            let limbi = [...new Set(produse.map(function(carte){
                return carte.limba;
            }).filter(Boolean))].sort();

            let teme = [...new Set(produse.flatMap(function(carte){
                return carte.teme || [];
            }))].sort();
        %>

        <section class="zona filtre-produse" id="sectiune-filtre-produse">
            <h2>Filtrează cărțile</h2>

            <p class="explicatie-filtre">
                Completează filtrele de mai jos pentru a afișa doar cărțile care corespund criteriilor alese.
            </p>

            <div class="row g-3 align-items-start campuri-filtrare">
                <div class="col-12 col-md-6 col-xl-3">
                    <div class="form-floating">
                        <textarea
                            class="form-control form-control-lg"
                            id="filtru-nume-start"
                            placeholder="ex: Misterul"
                            style="height: 5.5rem"></textarea>

                        <label for="filtru-nume-start">Numele începe cu</label>

                        <div class="invalid-feedback">
                            Introdu doar litere, spații, apostrof sau cratimă.
                        </div>
                    </div>
                </div>

                <div class="col-12 col-md-6 col-xl-3">
                    <label for="filtru-cuvant-descriere" class="form-label fw-bold">
                        Cuvânt în descriere
                    </label>

                    <input
                        type="text"
                        class="form-control form-control-lg"
                        id="filtru-cuvant-descriere"
                        placeholder="ex: bibliotecă">
                </div>

                <div class="col-12 col-md-6 col-xl-3">
                    <label for="filtru-autor" class="form-label fw-bold">
                        Autor
                    </label>

                    <input
                        type="text"
                        class="form-control form-control-lg"
                        id="filtru-autor"
                        list="lista-autori"
                        placeholder="alege sau scrie autorul">

                    <datalist id="lista-autori">
                        <% for (let autor of autori) { %>
                            <option value="<%= autor %>"></option>
                        <% } %>
                    </datalist>
                </div>

                <div class="col-12 col-md-6 col-xl-3">
                    <label for="filtru-limba" class="form-label fw-bold">
                        Limbă
                    </label>

                    <select id="filtru-limba" class="form-select form-select-lg">
                        <option value="">Oricare</option>

                        <% for (let limba of limbi) { %>
                            <option value="<%= limba %>">
                                <%= etichetaCategorie(limba) %>
                            </option>
                        <% } %>
                    </select>
                </div>

                <div class="col-12 col-lg-6">
                    <label for="filtru-pret" class="form-label fw-bold">
                        Preț maxim
                    </label>

                    <div class="d-flex align-items-center gap-2 linie-range">
                        <span><%= pretMin %></span>

                        <input
                            type="range"
                            class="form-range flex-grow-1"
                            id="filtru-pret"
                            min="<%= pretMin %>"
                            max="<%= pretMax %>"
                            value="<%= pretMax %>">

                        <span>
                            <%= pretMax %>
                            (<span id="valoare-pret-selectat"><%= pretMax %></span> RON)
                        </span>
                    </div>
                </div>

                <fieldset class="col-12 col-lg-6">
                    <legend class="form-label fw-bold mb-2">
                        Format carte
                    </legend>

                    <div class="btn-group flex-wrap gap-2" role="group" aria-label="Filtru format carte">
                        <input
                            type="radio"
                            class="btn-check"
                            name="filtru-format"
                            id="format-orice"
                            value=""
                            autocomplete="off"
                            checked>

                        <label class="btn btn-outline-primary btn-sm" for="format-orice">
                            Orice format
                        </label>

                        <% for (let format of formate) { %>
                            <% let idFormat = "format-" + format.replace(/[^a-zA-Z0-9_-]/g, "-"); %>

                            <input
                                type="radio"
                                class="btn-check"
                                name="filtru-format"
                                id="<%= idFormat %>"
                                value="<%= format %>"
                                autocomplete="off">

                            <label class="btn btn-outline-primary btn-sm" for="<%= idFormat %>">
                                <%= etichetaCategorie(format) %>
                            </label>
                        <% } %>
                    </div>
                </fieldset>

                <div class="col-12 col-md-6 col-xl-3">
                    <div class="form-check form-switch mt-md-4">
                        <input
                            class="form-check-input"
                            type="checkbox"
                            role="switch"
                            id="filtru-noutati">

                        <label class="form-check-label fw-bold" for="filtru-noutati">
                            noutăți
                        </label>
                    </div>
                </div>

                <div class="col-12 col-md-6 col-xl-5">
                    <label for="filtru-teme" class="form-label fw-bold">
                        Teme
                    </label>

                    <select id="filtru-teme" class="form-select" multiple size="5">
                        <% for (let tema of teme) { %>
                            <option value="<%= tema %>"><%= tema %></option>
                        <% } %>
                    </select>

                    <div class="form-text">
                        Ține apăsat Ctrl pentru mai multe opțiuni.
                    </div>
                </div>
            </div>

            <div class="butoane-filtrare d-flex flex-wrap gap-2 align-items-center mt-4">
                <button type="button" id="buton-filtreaza" class="btn btn-primary btn-lg">
                    <i class="bi bi-funnel-fill" aria-hidden="true"></i>
                    <span class="d-none d-sm-inline ms-1">filtreaza</span>
                </button>

                <button type="button" id="sortare-crescatoare" class="btn btn-secondary btn-lg">
                    <i class="bi bi-sort-alpha-down" aria-hidden="true"></i>
                    <span class="d-none d-sm-inline ms-1">Sortează crescător</span>
                </button>

                <button type="button" id="sortare-descrescatoare" class="btn btn-secondary btn-lg">
                    <i class="bi bi-sort-alpha-up-alt" aria-hidden="true"></i>
                    <span class="d-none d-sm-inline ms-1">Sortează descrescător</span>
                </button>

                <button type="button" id="calculeaza-preturi" class="btn btn-success btn-lg">
                    <i class="bi bi-calculator-fill" aria-hidden="true"></i>
                    <span class="d-none d-sm-inline ms-1">Calculează media</span>
                </button>

                <button type="button" id="resetare-filtre" class="btn btn-outline-danger btn-lg">
                    <i class="bi bi-arrow-counterclockwise" aria-hidden="true"></i>
                    <span class="d-none d-sm-inline ms-1">Resetează filtrele</span>
                </button>

                <p id="mesaj-produse-afisate" class="mb-0 ms-sm-2 fw-bold text-primary">
                    Se afișează <span id="numar-produse-afisate"><%= produse.length %></span>
                    din <%= produse.length %> produse.
                </p>
            </div>
        </section>

        <section id="lista-produse" class="grid-produse">
            <% for (let carte of produse) { %>
                <article
                    id="artc-<%= carte.id %>"
                    class="produs-card <%= carte.categorie %>"
                    data-nume="<%= (carte.nume || '').toLowerCase() %>"
                    data-descriere="<%= (carte.descriere || '').toLowerCase() %>"
                    data-autor="<%= (carte.autor || '').toLowerCase() %>"
                    data-pret="<%= Number(carte.pret) %>"
                    data-pagini="<%= Number(carte.numar_pagini) %>"
                    data-format="<%= carte.format %>"
                    data-limba="<%= carte.limba %>"
                    data-teme="<%= carte.teme ? carte.teme.join('|').toLowerCase() : '' %>"
                    data-semn="<%= carte.include_semn_carte %>"
                    data-adaugare="<%= dataPentruDatetime(carte.data_adaugare) %>">

                    <h3>
                        <a href="/produs/<%= carte.id %>">
                            <%= carte.nume %>
                        </a>
                    </h3>

                    <div class="continut-produs">
                        <div class="coloana-produs-imagine">
                            <img
                                src="<%= carte.imagine || '/resurse/imagini/coperta-mica.png' %>"
                                alt="Coperta cărții <%= carte.nume %>">

                            <ul class="lista-caracteristici">
                                <li>
                                    <strong>Preț:</strong>
                                    <span><%= Number(carte.pret).toFixed(2) %> RON</span>
                                </li>

                                <li>
                                    <strong>Pagini:</strong>
                                    <span><%= carte.numar_pagini %></span>
                                </li>

                                <li>
                                    <strong>Limbă:</strong>
                                    <span><%= etichetaCategorie(carte.limba) %></span>
                                </li>

                                <li>
                                    <strong>Teme:</strong>
                                    <span><%= carte.teme ? carte.teme.join(", ") : "—" %></span>
                                </li>

                                <li>
                                    <strong>Adăugată:</strong>
                                    <time datetime="<%= dataPentruDatetime(carte.data_adaugare) %>">
                                        <%= formatDataRomana(carte.data_adaugare) %>
                                    </time>
                                </li>

                                <li>
                                    <strong>Semn de carte:</strong>
                                    <span><%= carte.include_semn_carte ? "Da" : "Nu" %></span>
                                </li>
                            </ul>
                        </div>

                        <div class="coloana-produs-info">
                            <p class="autor-produs">
                                <strong>Autor:</strong>
                                <span><%= carte.autor || "—" %></span>
                            </p>

                            <p class="categorie-produs">
                                <strong>Categorie:</strong>
                                <span><%= etichetaCategorie(carte.categorie) %></span>
                            </p>

                            <p class="format-produs">
                                <strong>Format:</strong>
                                <span><%= etichetaCategorie(carte.format) %></span>
                            </p>

                            <p class="descriere-produs">
                                <%= carte.descriere %>
                            </p>

                            <p>
                                <a class="buton-detalii-produs" href="/produs/<%= carte.id %>">
                                    Vezi detalii
                                </a>
                            </p>
                        </div>
                    </div>
                </article>
            <% } %>
        </section>
    </main>

    <%- include("../fragmente/footer") %>

    <script src="/resurse/js/produse.js"></script>
</body>
</html>